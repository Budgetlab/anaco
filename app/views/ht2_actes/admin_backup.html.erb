<div class="fr-container-blue">
  <div class="fr-container">
    <div class="fr-grid-row fr-grid-row--middle fr-py-3w">
      <div class="fr-col-12">
        <h1 class="fr-h2 fr-mb-0">Sauvegarde des données</h1>
        <p class="fr-text--sm fr-mt-1w fr-mb-0">Export complet des tables ht2_actes, suspensions, poste_lignes, echeanciers</p>
      </div>
    </div>
  </div>
</div>

<div class="fr-container fr-my-4w">
  <div class="fr-grid-row fr-grid-row--gutters">

    <div class="fr-col-12 fr-col-lg-5">
      <div class="fr-card fr-p-4w">
        <h2 class="fr-h4">Lancer une nouvelle sauvegarde</h2>
        <p class="fr-text--sm fr-mb-1w">Le fichier contiendra 4 onglets :</p>
        <ul class="fr-list fr-mb-3w fr-text--sm">
          <li><strong>ht2_actes</strong> — <%= Ht2Acte.count %> enregistrements</li>
          <li><strong>suspensions</strong> — <%= Suspension.count %> enregistrements</li>
          <li><strong>poste_lignes</strong> — <%= PosteLigne.count %> enregistrements</li>
          <li><strong>echeanciers</strong> — <%= Echeancier.count %> enregistrements</li>
        </ul>
        <%= button_to "Générer la sauvegarde", generate_backup_path,
            method: :post,
            class: "fr-btn fr-icon-save-line fr-btn--icon-left",
            data: { turbo_confirm: "Lancer la génération de la sauvegarde ? Cela peut prendre plusieurs minutes." } %>
      </div>
    </div>

    <div class="fr-col-12 fr-col-lg-7">
      <div class="fr-card fr-p-4w">
        <h2 class="fr-h4">Sauvegardes récentes</h2>
        <% if @backups.any? %>
          <div class="fr-table fr-table--sm fr-table--no-caption">
            <div class="fr-table__wrapper">
              <div class="fr-table__container">
                <div class="fr-table__content">
                  <table>
                    <thead>
                      <tr>
                        <th>Date</th>
                        <th>Statut</th>
                        <th>Fichier</th>
                        <th></th>
                      </tr>
                    </thead>
                    <tbody>
                      <% @backups.each do |backup| %>
                        <tr>
                          <td><%= l(backup.created_at, format: :long) %></td>
                          <td>
                            <% if backup.status == 'generating' %>
                              <p class="fr-badge fr-badge--sm fr-badge--warning">En cours...</p>
                            <% elsif backup.status == 'completed' %>
                              <p class="fr-badge fr-badge--sm fr-badge--success">Terminé</p>
                            <% elsif backup.status == 'failed' %>
                              <p class="fr-badge fr-badge--sm fr-badge--error" title="<%= backup.error_message %>">Erreur</p>
                            <% end %>
                          </td>
                          <td class="fr-text--sm"><%= backup.filename %></td>
                          <td>
                            <div class="fr-btns-group fr-btns-group--inline fr-btns-group--sm">
                              <% if backup.status == 'completed' %>
                                <%= link_to "Télécharger", download_backup_path(backup),
                                    class: "fr-btn fr-btn--sm fr-btn--secondary fr-icon-download-line fr-btn--icon-left" %>
                              <% end %>
                              <%= button_to "Supprimer", destroy_backup_path(backup),
                                  method: :delete,
                                  class: "fr-btn fr-btn--sm fr-btn--tertiary-no-outline fr-icon-delete-line fr-btn--icon-left",
                                  data: { turbo_confirm: "Supprimer cette sauvegarde et le fichier associé ?" } %>
                            </div>
                          </td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        <% else %>
          <div class="fr-alert fr-alert--info">
            <p>Aucune sauvegarde générée pour le moment.</p>
          </div>
        <% end %>
      </div>
    </div>

  </div>
</div>
